# Fleet Manager Configuration
# Copy to .env and edit as needed: cp .env.example .env

# Server
FLEET_HOST=127.0.0.1
FLEET_PORT=7700

# Auth token (protects API, MCP, WebSocket, and Web UI)
FLEET_AUTH_TOKEN=

# Telegram notifications (optional)
FLEET_TELEGRAM_TOKEN=
FLEET_TELEGRAM_CHAT_ID=

# Orchestrator (optional, for fleet-orchestrator command)
ANTHROPIC_API_KEY=
FLEET_URL=http://127.0.0.1:7700
FLEET_ORCHESTRATOR_MODEL=claude-sonnet-4-6
