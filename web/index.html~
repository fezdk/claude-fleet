<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Claude Fleet Manager</title>
  <script>if(localStorage.getItem('fleet_theme')==='dark')document.documentElement.setAttribute('data-theme','dark')</script>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header id="app-header" class="hidden">
    <h1>Fleet Manager</h1>
    <div class="view-mode-selector">
      <button class="view-mode-btn active" data-mode="list" title="List view" onclick="setViewMode('list')">☰</button>
      <button class="view-mode-btn" data-mode="tab" title="Tab view" onclick="setViewMode('tab')">▭</button>
      <button class="view-mode-btn" data-mode="sidetab" title="Side-tab view" onclick="setViewMode('sidetab')">◫</button>
    </div>
    <div class="header-right">
      <button id="new-session-btn" class="btn-sm btn-accent" onclick="showNewSessionModal()">+<span class="btn-label"> New Session</span></button>
      <button class="btn-sm" onclick="openMultiView()">⊞<span class="btn-label"> Multi View</span></button>
      <span id="session-count" class="badge badge-info"><span class="count-num">0</span><span class="btn-label"> sessions</span></span>
      <span id="ws-status" class="badge badge-disconnected"><span class="ws-dot">●</span><span class="btn-label"> disconnected</span></span>
      <button id="theme-toggle" class="btn-sm" onclick="toggleTheme()" title="Toggle dark/light theme">🌙</button>
      <button id="logout-btn" class="btn-sm hidden" onclick="logout()">Logout</button>
    </div>
  </header>

  <main id="app-main" class="hidden">
    <!-- Dashboard: session list -->
    <section id="dashboard">
      <div id="pending-questions-banner" class="banner hidden">
        <span id="pending-count">0</span> pending question(s) across sessions
      </div>
      <!-- List view (default) -->
      <div id="view-list" class="view-container"></div>
      <!-- Tab view -->
      <div id="view-tab" class="view-container hidden">
        <div id="tab-bar" class="tab-bar"></div>
        <div id="tab-questions" class="tab-questions"></div>
        <pre id="tab-terminal" class="tab-terminal"></pre>
        <div id="tab-keys-bar" class="keys-bar"></div>
        <form id="tab-message-form" class="focus-input-area">
          <input type="text" id="tab-msg-input" placeholder="Send instructions..." autocomplete="off">
          <button type="submit" class="btn-accent">Send</button>
        </form>
        <div id="tab-msg-status" class="msg-status hidden"></div>
      </div>
      <!-- Side-tab view -->
      <div id="view-sidetab" class="view-container hidden">
        <div class="sidetab-layout">
          <div id="sidetab-panel" class="sidetab-panel"></div>
          <div class="sidetab-content">
            <div id="sidetab-questions" class="sidetab-questions"></div>
            <pre id="sidetab-terminal" class="sidetab-terminal"></pre>
            <div id="sidetab-keys-bar" class="keys-bar"></div>
            <form id="sidetab-message-form" class="focus-input-area">
              <input type="text" id="sidetab-msg-input" placeholder="Send instructions..." autocomplete="off">
              <button type="submit" class="btn-accent">Send</button>
            </form>
            <div id="sidetab-msg-status" class="msg-status hidden"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Session detail (hidden by default) -->
    <section id="session-detail" class="hidden">
      <nav class="detail-nav">
        <button id="back-btn" onclick="showDashboard()">&larr; All Sessions</button>
        <div class="detail-nav-actions">
          <button class="btn-sm btn-accent" onclick="openFocus(currentSessionId)">Open Focus</button>
          <button class="btn-sm" onclick="loadOutput(currentSessionId)">Refresh Output</button>
          <button class="btn-sm btn-warning" onclick="unstickSession(currentSessionId)" title="Send 'wait' + Enter to unstick">Unstick</button>
          <button class="btn-sm btn-danger" onclick="deleteCurrentSession()">Remove</button>
        </div>
      </nav>
      <div id="detail-header"></div>

      <div class="panel-grid">
        <div class="panel">
          <h3>Pending Questions</h3>
          <div id="questions-container"></div>
        </div>
        <div class="panel">
          <h3>Send Message</h3>
          <form id="message-form">
            <textarea id="message-input" placeholder="Type instructions for this session..." rows="3"></textarea>
            <div class="form-actions">
              <label><input type="checkbox" id="msg-urgent"> Urgent (interrupt working session)</label>
              <button type="submit">Send</button>
            </div>
          </form>
          <div id="message-status" class="msg-status hidden"></div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <h3>Terminal Output</h3>
          <label class="toggle-label">
            <input type="checkbox" id="auto-refresh-toggle" onchange="toggleAutoRefresh()">
            Auto-refresh
          </label>
        </div>
        <pre id="terminal-output"></pre>
        <div id="detail-keys-bar" class="keys-bar"></div>
        <div id="detail-msg-status" class="msg-status hidden"></div>
      </div>

      <div class="panel">
        <h3>Status History</h3>
        <div id="status-log"></div>
      </div>
    </section>
  </main>

  <!-- Multi View Modal -->
  <div id="multi-overlay" class="focus-overlay hidden" onclick="if(event.target===this)closeMultiView()">
    <div class="multi-modal">
      <div class="multi-header">
        <h2>All Sessions</h2>
        <button class="btn-sm" onclick="closeMultiView()">Close</button>
      </div>
      <div id="multi-grid"></div>
    </div>
  </div>

  <!-- Session Focus Modal -->
  <div id="focus-overlay" class="focus-overlay hidden" onclick="if(event.target===this)closeFocus()">
    <div class="focus-modal">
      <div class="focus-header">
        <div class="focus-title">
          <h2 id="focus-name"></h2>
          <span id="focus-state" class="state"></span>
          <span id="focus-summary" class="focus-summary-text"></span>
        </div>
        <div class="focus-actions">
          <button class="btn-sm" onclick="openDetailFromFocus()">Detail</button>
          <button class="btn-sm" onclick="openEditor(focusSessionId)">Edit</button>
          <button id="focus-fork-btn" class="btn-sm btn-accent hidden" onclick="forkFocusSession()">Fork</button>
          <button class="btn-sm btn-warning" onclick="unstickSession(focusSessionId)" title="Send 'wait' + Enter to unstick a stuck session">Unstick</button>
          <button class="btn-sm btn-danger" onclick="deleteFocusSession()">Stop</button>
          <button class="btn-sm" onclick="closeFocus()">Close</button>
        </div>
      </div>
      <pre id="focus-terminal"></pre>
      <div id="focus-keys-bar" class="keys-bar">
        <div class="keys-group">
          <button class="key-btn" onclick="sendKey('Up')" title="Up arrow">&#9650;</button>
          <button class="key-btn" onclick="sendKey('Down')" title="Down arrow">&#9660;</button>
          <button class="key-btn" onclick="sendKey('Left')" title="Left arrow">&#9664;</button>
          <button class="key-btn" onclick="sendKey('Right')" title="Right arrow">&#9654;</button>
        </div>
        <div class="keys-group">
          <button class="key-btn key-wide" onclick="sendKey('Enter')" title="Enter">Enter &#9166;</button>
          <button class="key-btn" onclick="sendKey('Escape')" title="Escape">Esc</button>
          <button class="key-btn" onclick="sendKey('Tab')" title="Tab">Tab</button>
        </div>
        <div class="keys-group">
          <button class="key-btn key-confirm" onclick="sendKey('y')" title="Yes">y</button>
          <button class="key-btn key-deny" onclick="sendKey('n')" title="No">n</button>
          <button class="key-btn" onclick="sendKey('Space')" title="Space">Space</button>
        </div>
        <div class="keys-group">
          <div class="cmd-dropdown-wrapper">
            <button class="key-btn key-cmd" onclick="toggleCommandDropdown()" title="Send command (no [fleet] prefix)">/ Cmd</button>
            <div id="cmd-dropdown" class="cmd-dropdown hidden">
              <div class="cmd-dropdown-item" onclick="sendCommand('/help')">
                <span class="cmd-name">/help</span><span class="cmd-desc">Show help</span>
              </div>
              <div class="cmd-dropdown-item" onclick="sendCommand('/status')">
                <span class="cmd-name">/status</span><span class="cmd-desc">Check status</span>
              </div>
              <div class="cmd-dropdown-item" onclick="sendCommand('/review')">
                <span class="cmd-name">/review</span><span class="cmd-desc">Review changes</span>
              </div>
              <div class="cmd-dropdown-item" onclick="sendCommand('/commit')">
                <span class="cmd-name">/commit</span><span class="cmd-desc">Commit staged</span>
              </div>
              <div class="cmd-dropdown-item" onclick="sendCommand('/clear')">
                <span class="cmd-name">/clear</span><span class="cmd-desc">Clear context</span>
              </div>
              <div class="cmd-dropdown-item" onclick="sendCommand('/resume')">
                <span class="cmd-name">/resume</span><span class="cmd-desc">Resume previous session</span>
              </div>
              <div class="cmd-dropdown-divider"></div>
              <div class="cmd-dropdown-custom">
                <input type="text" id="cmd-custom-input" placeholder="Custom message..." autocomplete="off"
                       onkeydown="if(event.key==='Enter'){event.preventDefault();sendCustomCommand()}">
                <button onclick="sendCustomCommand()" class="btn-sm btn-accent">Send</button>
              </div>
            </div>
          </div>
        </div>
        <div class="keys-group keys-right">
          <label class="toggle-label" title="Capture keyboard input and forward keypresses directly to the terminal session"><input type="checkbox" id="keyboard-capture-toggle" onchange="toggleKeyboardCapture()"> Keyboard</label>
        </div>
      </div>
      <form id="focus-message-form" class="focus-input-area">
        <input type="text" id="focus-msg-input" placeholder="Send instructions..." autocomplete="off">
        <button type="submit" class="btn-accent">Send</button>
      </form>
      <div id="focus-msg-status" class="msg-status hidden"></div>
    </div>
  </div>

  <!-- File Editor Overlay -->
  <div id="editor-overlay" class="focus-overlay hidden" onclick="if(event.target===this)closeEditor()">
    <div class="editor-modal">
      <div class="editor-header">
        <div class="editor-title">
          <h2 id="editor-session-name"></h2>
          <span id="editor-breadcrumb" class="editor-breadcrumb"></span>
          <span id="editor-permission" class="editor-perm"></span>
        </div>
        <div class="editor-actions">
          <button id="editor-save-btn" class="btn-sm btn-accent" onclick="editorSave()" disabled>Save</button>
          <button class="btn-sm" onclick="closeEditor()">Close</button>
        </div>
      </div>
      <div id="editor-picker" class="editor-picker">
        <div class="editor-picker-nav">
          <button id="editor-up-btn" class="btn-sm" onclick="editorNavigateUp()" title="Parent directory">.. up</button>
          <span id="editor-cwd" class="editor-cwd"></span>
          <label class="toggle-label"><input type="checkbox" id="editor-show-hidden" onchange="editorRefreshDir()"> Hidden</label>
        </div>
        <div id="editor-file-list" class="editor-file-list"></div>
      </div>
      <div id="editor-content" class="editor-content hidden">
        <div class="editor-toolbar">
          <button class="btn-sm" onclick="editorBackToPicker()">Browse</button>
          <span id="editor-filename" class="editor-filename"></span>
          <span id="editor-size" class="editor-size"></span>
          <span id="editor-dirty" class="editor-dirty hidden">Modified</span>
        </div>
        <div class="editor-body">
          <div id="editor-line-numbers" class="editor-line-numbers"></div>
          <textarea id="editor-textarea" class="editor-textarea" spellcheck="false"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Peek Last Overlay -->
  <div id="peek-overlay" class="focus-overlay hidden" onclick="if(event.target===this)closePeek()">
    <div class="editor-modal">
      <div class="editor-header">
        <div class="editor-title">
          <h2 id="peek-title">Peek Last Lines</h2>
          <span id="peek-breadcrumb" class="editor-breadcrumb"></span>
        </div>
        <div class="editor-actions">
          <button class="btn-sm" onclick="closePeek()">Close</button>
        </div>
      </div>
      <div id="peek-picker" class="editor-picker">
        <div class="editor-picker-nav">
          <button id="peek-up-btn" class="btn-sm" onclick="peekNavigateUp()" title="Parent directory">.. up</button>
          <span id="peek-cwd" class="editor-cwd"></span>
        </div>
        <div id="peek-file-list" class="editor-file-list"></div>
      </div>
      <div id="peek-content" class="editor-content hidden">
        <div class="editor-toolbar">
          <button class="btn-sm" onclick="peekBackToPicker()">Browse</button>
          <span id="peek-filename" class="editor-filename"></span>
          <span id="peek-info" class="editor-size"></span>
        </div>
        <div class="editor-body">
          <pre id="peek-text" class="peek-text"></pre>
        </div>
      </div>
    </div>
  </div>

  <!-- Question Modal (on top of focus) -->
  <div id="question-overlay" class="focus-overlay hidden" onclick="if(event.target===this)closeQuestionModal()">
    <div class="login-card question-modal-card">
      <h2>Question from <span id="qm-session"></span></h2>
      <div id="qm-questions"></div>
      <button class="btn-sm" onclick="closeQuestionModal()" style="margin-top:0.75rem;width:100%">Dismiss</button>
    </div>
  </div>

  <!-- New Session Modal -->
  <div id="new-session-overlay" class="login-overlay hidden">
    <div class="login-card">
      <h2>New Session</h2>
      <p>Start a new agent session.</p>
      <form id="new-session-form">
        <label class="form-label" for="ns-agent">Agent</label>
        <select id="ns-agent" required>
          <option value="opencode">OpenCode</option>
          <option value="claude-code">Claude Code</option>
          <option value="copilot">Copilot</option>
        </select>
        <label class="form-label" for="ns-project">Project path</label>
        <div class="path-autocomplete-wrapper">
          <input type="text" id="ns-project" placeholder="/home/user/projects/myapp" required
                 oninput="autoFillSessionName(); onPathInput()" autocomplete="off">
          <div id="path-autocomplete" class="path-autocomplete hidden"></div>
        </div>
        <label class="form-label" for="ns-name">Session name</label>
        <input type="text" id="ns-name" placeholder="(auto from path)">
        <div id="ns-error" class="login-error hidden"></div>
        <div class="modal-actions">
          <button type="button" class="btn-sm" onclick="hideNewSessionModal()">Cancel</button>
          <button type="submit" id="ns-submit">Start</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Login Modal -->
  <div id="login-overlay" class="login-overlay hidden">
    <div class="login-card">
      <h2>Fleet Manager</h2>
      <p>Enter your auth token to continue.</p>
      <form id="login-form">
        <input type="password" id="login-token" placeholder="Auth token" autocomplete="off" required>
        <div id="login-error" class="login-error hidden">Invalid token</div>
        <button type="submit">Login</button>
      </form>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>
